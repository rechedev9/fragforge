/bin/
/data/*
# Local observability output (error journal + Prometheus counters), at any depth
# so a stray run from a package dir during tests is never tracked.
**/data/obs/
!/data/lineups/
!/data/lineups/*.json
# Music: commit only the catalog metadata + attribution (text), never the audio.
# scripts/fetch-music.sh re-downloads tracks from catalog.json into ZV_MUSIC_DIR.
!/data/music/
/data/music/*
!/data/music/catalog.json
!/data/music/ATTRIBUTION.md
/.env

# Built binaries
*.exe

# Generated media and overlay renders
*.dem
*.mp4
*.mov
*.webm
*.avi
*.mkv
*.wav
*.flac
*.aac
*.tga
*.exr
*.y4m
*.yuv
frames/
*/frames/
overlays/**/dist/
overlays/**/render/
overlays/**/renders/
overlays/**/out/

# Local demos and goldens (per testdata/README.md)
/testdata/*.dem
/testdata/*.expected.json

# Editor / OS noise
.DS_Store
.idea/
.vscode/
*.swp

# Local frontend toolchains
/internal/httpapi/workbench_assets/node_modules/

# Local one-box deploy data (scripts/run-local.sh)
/.local/

# Local git worktrees
/.worktrees/
/.claude/worktrees/

# Logs
*.log
logs/

# Playwright agent CLI session artifacts (snapshots, console/network logs)
/.playwright-cli/

# Playwright test runner output
web/test-results/
web/playwright-report/

# Firecrawl local cache / outputs
/.firecrawl/

# Autonomous-loop blueprint/state (agent-local, never committed)
.loop/
.loop_tmp_crops/

# Local Vercel project links and build output.
.vercel/
# Local Pi runtime state
.atl/

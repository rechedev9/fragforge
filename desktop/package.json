{
  "name": "fragforge-studio",
  "version": "0.3.1",
  "private": true,
  "description": "FragForge Studio - desktop Local Studio: web UI + local HLAE/CS2 capture in one app",
  "author": "FragForge",
  "main": "main.js",
  "scripts": {
    "assemble": "node scripts/assemble.mjs",
    "start": "electron .",
    "dist": "npm run assemble && electron-builder --win nsis"
  },
  "devDependencies": {
    "electron": "^43.0.0",
    "electron-builder": "^26.0.0"
  },
  "build": {
    "appId": "com.fragforge.studio",
    "productName": "FragForge Studio",
    "directories": {
      "output": "dist-installer"
    },
    "files": [
      "main.js",
      "loading.html",
      "pair.html"
    ],
    "extraResources": [
      {
        "from": "build-resources/web",
        "to": "web"
      },
      {
        "from": "build-resources/web/node_modules",
        "to": "web/node_modules"
      },
      {
        "from": "build-resources/bin",
        "to": "bin"
      },
      {
        "from": "build-resources/music",
        "to": "music"
      }
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
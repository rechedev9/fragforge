{
  "name": "fragforge-studio",
  "version": "2.0.3",
  "private": true,
  "description": "FragForge Studio - desktop Local Studio: web UI + local HLAE/CS2 capture in one app",
  "author": "FragForge",
  "main": "dist/main.js",
  "scripts": {
    "build": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\" && tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src",
    "test:unit": "node --test \"src/**/*.test.ts\" \"scripts/**/*.test.mjs\"",
    "assemble": "node scripts/assemble.mjs",
    "assemble:team": "node scripts/assemble.mjs --team-xai-key",
    "start": "npm run build && electron .",
    "dist": "node scripts/dist.mjs",
    "dist:team": "node scripts/dist.mjs --team-xai-key"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "electron": "^43.0.0",
    "electron-builder": "^26.0.0",
    "oxlint": "^1.72.0",
    "oxlint-tsgolint": "^0.24.0",
    "typescript": "^5.7.0"
  },
  "build": {
    "appId": "com.fragforge.studio",
    "productName": "FragForge Studio",
    "directories": {
      "output": "dist-installer"
    },
    "files": [
      "dist/**/*",
      "loading.html"
    ],
    "extraResources": [
      {
        "from": "build-resources/web",
        "to": "web"
      },
      {
        "from": "build-resources/web/node_modules",
        "to": "web/node_modules"
      },
      {
        "from": "build-resources/bin",
        "to": "bin"
      },
      {
        "from": "build-resources/music",
        "to": "music"
      },
      {
        "from": "build-resources/team/xai-api-key",
        "to": "team/xai-api-key"
      }
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}

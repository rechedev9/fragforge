#!/bin/sh
# Keep AGENTS.md as a symbolic link to CLAUDE.md.
# CLAUDE.md is the single source of truth for agent instructions; edit it only.
set -e

root="$(git rev-parse --show-toplevel)"
cd "$root"

if [ ! -L AGENTS.md ] || [ "$(readlink AGENTS.md)" != "CLAUDE.md" ]; then
  echo "pre-commit: AGENTS.md must be a symbolic link to CLAUDE.md" >&2
  exit 1
fi

# FragForge web — environment template. Copy to `.env.local` and fill in.
# `.env.local` is gitignored; never commit real secrets.

# Use the real backend (Steam OpenID + same-origin /api/* routes + the
# orchestrator). Leave UNSET to run entirely against the in-memory mock
# (no Steam, no pairing — handy for UI work).
NEXT_PUBLIC_API_BASE=/api

# Data-plane mode: 'local' | 'cloud' | 'hosted'. Unset defaults to 'cloud'.
# - local:  the web is a same-origin proxy to a local orchestrator on this PC.
# - cloud:  hosted control-plane; a paired desktop agent does the work.
# - hosted: Topology A. The SPA is served from OUR domain but the browser (on
#           the user PC) talks DIRECTLY to a LOCAL agent at a configurable base
#           URL, sending X-FragForge-Token on every request. No job traffic and
#           no video ever transit our server. The agent URL + pairing token are
#           client-side settings (localStorage ff_agent_url / ff_agent_token),
#           NOT env vars; the agent-side ZV_ALLOWED_WEB_ORIGINS / ZV_MUTATION_TOKEN
#           live in the Go service.
NEXT_PUBLIC_FRAGFORGE_MODE=cloud

# Required for REAL match-history linking. Without it, "Load my matches"
# returns 503 and the UI tells you to skip and link later.
# Get a free key (signed in to Steam): https://steamcommunity.com/dev/apikey
STEAM_WEB_API_KEY=

# Signs the session cookie. Use a strong random value (>=16 chars).
# Required in production; a dev default is used locally if unset.
ZV_SESSION_SECRET=

# SQLite accounts DB (Steam login upsert -> ff_session). Node's built-in
# node:sqlite backs it; no native module. Parent dir is created on first use
# and WAL is enabled. Defaults to /data/fragforge.db when unset.
FRAGFORGE_SQLITE_PATH=/data/fragforge.db

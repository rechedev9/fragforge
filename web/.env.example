# FragForge web — environment template. Copy to `.env.local` and fill in.
# `.env.local` is gitignored; never commit real secrets.

# Same-origin /api/* routes proxy to this server-side orchestrator address.
# The loopback default is shown explicitly for local development.
ORCHESTRATOR_URL=http://127.0.0.1:8080

# Only needed when the orchestrator uses a mutation token.
# ORCHESTRATOR_TOKEN=

# FragForge web — environment template. Copy to `.env.local` and fill in.
# `.env.local` is gitignored; never commit real secrets.

# Use the real backend (Steam OpenID + same-origin /api/* routes + the
# orchestrator). Leave UNSET to run entirely against the in-memory mock
# (no Steam, no pairing — handy for UI work).
NEXT_PUBLIC_API_BASE=/api

# Selects the data plane. "local": the web talks only to a local orchestrator
# on this machine (see docs/local-studio.md). Any other value (including
# unset) is cloud mode: a paired desktop agent captures, and the browser
# talks to it directly over a loopback proxy after pairing through Supabase.
# This is a public var baked into the client bundle at build time (see
# web/Dockerfile's FRAGFORGE_MODE build arg for the Docker/VPS builds).
NEXT_PUBLIC_FRAGFORGE_MODE=

# Required for REAL match-history linking. Without it, "Load my matches"
# returns 503 and the UI tells you to skip and link later.
# Get a free key (signed in to Steam): https://steamcommunity.com/dev/apikey
STEAM_WEB_API_KEY=

# Signs the session cookie. Use a strong random value (>=16 chars).
# Required in production; a dev default is used locally if unset.
ZV_SESSION_SECRET=

# Cloud mode only: the Supabase project holding control-plane state (users,
# agents). Never holds media; see
# docs/superpowers/specs/2026-07-08-local-first-cloud-data-plane.md.
# The service-role key is server-only (web/lib/supabase/server.ts) and must
# never reach the browser.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

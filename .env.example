ZV_HTTP_ADDR=:8080
ZV_DATABASE_URL=postgres://zackvideo:zackvideo@localhost:5432/zackvideo?sslmode=disable
ZV_REDIS_ADDR=localhost:6379
ZV_DATA_DIR=./data
ZV_WORKER_CONCURRENCY=2

# Optional media workers. Leave ZV_MEDIA_WORK_DIR unset to use temp workdirs
# that are deleted after each media task. Set it to keep workdirs for debugging.
# ZV_MEDIA_WORK_DIR=./data/work
ZV_RECORDER_PATH=
ZV_HLAE_PATH=
ZV_CS2_PATH=
ZV_RECORD_TIMEOUT=20m
ZV_COMPOSER_PATH=
ZV_FFMPEG_PATH=
ZV_COMPOSE_TIMEOUT=20m
